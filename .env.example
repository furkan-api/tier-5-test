# ------------------------------------------------------------------------------
# GraphRAG - Environment Variables
# Copy this file as .env and fill in your values.
# ------------------------------------------------------------------------------

# --- Embedding Settings -------------------------------------------------------
# Embedding provider: sentence_transformer | openai
EMBEDDING_PROVIDER=sentence_transformer

# Model name to use
# For sentence_transformer: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# For openai: text-embedding-3-small | text-embedding-3-large
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Embedding vector dimension (must be compatible with the model)
# paraphrase-multilingual-MiniLM-L12-v2 -> 384
# text-embedding-3-small -> 1536
EMBEDDING_DIMENSION=384

# Embedding batch size (number of texts to embed at once)
EMBEDDING_BATCH_SIZE=64

# --- OpenAI (only required if EMBEDDING_PROVIDER=openai) ---------------------
OPENAI_API_KEY=

# --- Graph Settings -----------------------------------------------------------
# Cosine similarity threshold for semantic similarity edges (0.0 - 1.0)
SIMILARITY_THRESHOLD=0.82

# Maximum number of semantic neighbors per node
MAX_NEIGHBORS=5

# FAISS index type: flat (exact, small data) | ivf (approximate, large data)
FAISS_INDEX_TYPE=flat

# --- Query Settings -----------------------------------------------------------
# Default number of results from vector search
QUERY_TOP_K=10

# Number of hops for graph expansion
QUERY_EXPAND_HOPS=2

# Maximum number of nodes during expansion
QUERY_MAX_EXPANDED=50

# Minimum similarity threshold (results below this are discarded)
QUERY_SCORE_THRESHOLD=0.3

# Context character limit sent to the LLM
QUERY_MAX_CONTEXT_CHARS=8000

# --- Paths (absolute or relative to project root) ----------------------------
# Leave empty to use defaults
GRAPH_DATA_DIR=
EDGE_RULES_PATH=
OUTPUT_DIR=

# --- Logging ------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
