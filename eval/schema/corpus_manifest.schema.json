{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Corpus Manifest",
  "description": "Metadata for all documents in the Turkish legal corpus",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["doc_id", "filename", "court", "daire", "law_branch", "court_level", "esas_no", "karar_no", "decision_date", "topic_keywords", "excluded"],
    "properties": {
      "doc_id": { "type": "string", "description": "Filename stem (no .md extension)" },
      "filename": { "type": "string" },
      "court": { "type": "string", "description": "Court type: Yargıtay, Danıştay, Sayıştay, AYM, Uyuşmazlık, AİHM, BAM, BİM, İlk Derece" },
      "daire": { "type": "string", "description": "Specific chamber/court name" },
      "law_branch": { "type": "string", "enum": ["hukuk", "ceza", "idari", "anayasa", ""] },
      "court_level": { "type": "integer", "minimum": 0, "maximum": 5, "description": "1=İlk Derece, 2=İstinaf (BAM/BİM), 3=Temyiz (Yargıtay/Danıştay/Sayıştay), 4=Anayasal+Uyuşmazlık (AYM/Uyuşmazlık), 5=Uluslararası (AİHM)" },
      "esas_no": { "type": "string" },
      "karar_no": { "type": "string" },
      "decision_date": { "type": "string", "description": "DD.MM.YYYY format" },
      "topic_keywords": { "type": "array", "items": { "type": "string" } },
      "excluded": { "type": "boolean" },
      "exclude_reason": { "type": "string" }
    }
  }
}
