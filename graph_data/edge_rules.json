{
  "description": "GraphRAG kenar (edge) kuralları. Her kural, hangi koşulda iki node arasında kenar oluşturulacağını tanımlar.",
  "rules": [
    {
      "rule_id": "kanun_madde_icerir",
      "edge_type": "ICERIR",
      "description": "Kanun node'u kendi maddelerini içerir",
      "source_node_type": "kanun",
      "target_node_type": "madde",
      "condition": {
        "type": "metadata_match",
        "source_field": "metadata.kisaltma",
        "target_field": "metadata.kanun_kisaltma"
      },
      "weight": 1.0,
      "bidirectional": false
    },
    {
      "rule_id": "madde_fikra_icerir",
      "edge_type": "ICERIR",
      "description": "Madde node'u kendi fıkralarını içerir",
      "source_node_type": "madde",
      "target_node_type": "fikra",
      "condition": {
        "type": "metadata_list_contains",
        "source_field": "metadata.fikralar",
        "target_field": "node_id"
      },
      "weight": 1.0,
      "bidirectional": false
    },
    {
      "rule_id": "fikra_ust_madde",
      "edge_type": "UST_NODE",
      "description": "Fıkra kendi üst maddesine bağlanır",
      "source_node_type": "fikra",
      "target_node_type": "madde",
      "condition": {
        "type": "field_equals_node_id",
        "source_field": "metadata.ust_node",
        "target_field": "node_id"
      },
      "weight": 1.0,
      "bidirectional": false
    },
    {
      "rule_id": "karar_kanun_atif",
      "edge_type": "ATIF_YAPAR",
      "description": "Karar, atıf yaptığı kanun maddelerine bağlanır (ör. TMK/706 → TMK_M706)",
      "source_node_type": ["karar", "karar_gerekce"],
      "target_node_type": "madde",
      "condition": {
        "type": "kanun_atif_parse",
        "source_field": "metadata.atif_yapilan_kanunlar"
      },
      "weight": 0.9,
      "bidirectional": false
    },
    {
      "rule_id": "karar_karar_atif",
      "edge_type": "ATIF_YAPAR",
      "description": "Karar, atıf yaptığı diğer kararlara bağlanır",
      "source_node_type": ["karar", "karar_gerekce"],
      "target_node_type": "karar",
      "condition": {
        "type": "id_list_reference",
        "source_field": "metadata.atif_yapilan_kararlar",
        "target_field": "node_id"
      },
      "weight": 0.85,
      "bidirectional": false
    },
    {
      "rule_id": "gerekce_karar_baglanti",
      "edge_type": "GEREKCESI",
      "description": "Karar gerekçesi, üst kararına bağlanır",
      "source_node_type": "karar_gerekce",
      "target_node_type": "karar",
      "condition": {
        "type": "field_equals_node_id",
        "source_field": "metadata.ust_karar",
        "target_field": "node_id"
      },
      "weight": 1.0,
      "bidirectional": false
    },
    {
      "rule_id": "ust_mahkeme_ilk_derece",
      "edge_type": "KANUN_YOLU",
      "description": "Üst mahkeme kararı, ilk derece kararına bağlanır (temyiz/istinaf)",
      "source_node_type": "karar",
      "target_node_type": "karar",
      "condition": {
        "type": "field_equals_node_id",
        "source_field": "metadata.ilk_derece_ref",
        "target_field": "node_id"
      },
      "weight": 0.95,
      "bidirectional": false
    },
    {
      "rule_id": "ayni_kanun_maddeleri",
      "edge_type": "AYNI_KANUN",
      "description": "Aynı kanuna ait maddeler arasında kenar oluşturulur",
      "source_node_type": "madde",
      "target_node_type": "madde",
      "condition": {
        "type": "metadata_match",
        "source_field": "metadata.kanun_no",
        "target_field": "metadata.kanun_no"
      },
      "weight": 0.3,
      "bidirectional": true
    },
    {
      "rule_id": "celisik_kararlar",
      "edge_type": "CELISIK_KARAR",
      "description": "Aynı hukuk dalında benzer konuda ancak zıt sonuca ulaşan kararlar arasında çelişki kenarı oluşturulur (ör. işçi lehine vs işveren lehine)",
      "source_node_type": "karar",
      "target_node_type": "karar",
      "condition": {
        "type": "contradictory_decisions",
        "similarity_threshold": 0.55
      },
      "weight": 0.8,
      "bidirectional": true
    },
    {
      "rule_id": "semantik_benzerlik",
      "edge_type": "SEMANTIK_BENZER",
      "description": "Embedding vektörleri arasında yüksek kosinüs benzerliği olan node'lar bağlanır",
      "source_node_type": "*",
      "target_node_type": "*",
      "condition": {
        "type": "cosine_similarity",
        "threshold": 0.82,
        "max_neighbors": 5,
        "exclude_self": true,
        "exclude_existing_edges": true
      },
      "weight_from_similarity": true,
      "bidirectional": true
    }
  ]
}
