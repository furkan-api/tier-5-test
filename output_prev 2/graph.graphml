      <data key="d38">HMK</data>
      <data key="d39">27</data>
      <data key="d44">2</data>
      <data key="d8">2011-10-01</data>
      <data key="d41">False</data>
      <data key="d19">hukuki dinlenilme hakkının unsurları: bilgi-açıklama-ispat-gerekçe</data>
      <data key="d25">usul hukuku</data>
      <data key="d45">HMK_M27</data>
    </node>
