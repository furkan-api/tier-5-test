      <data key="d17">2020-07-08</data>
      <data key="d19">tapu iptali ve tescil - sahte vekâletname - istihkap</data>
      <data key="d20">kabul</data>
      <data key="d22">["TMK/683", "TMK/716"]</data>
      <data key="d23">["YRG_HGK_2003_603"]</data>
      <data key="d24">İSTİNAFA GİTTİ</data>
      <data key="d33">KARAR_BAM_ERZ_2020_2891_SON_REF</data>
      <data key="d25">eşya hukuku</data>
    </node>
    <node id="KARAR_ID_2019_890_GEREKCESI">
      <data key="d0">karar_gerekce</data>
      <data key="d1">Davacı taşınmazın gerçek maliki olduğunu ileri sürmekte; sahte vekâletname ile yapılan tapu devrinin iptalini talep etmektedir. Adli bilirkişi incelemesinde vekâletnamenin sahte olduğu anlaşılmıştır. Sahte belgeyle yapılan işlem hukuken geçersizdir. TMK m.683 uyarınca mülkiyet hakkı koruması kapsamında tapu iptali talep hakkı doğmaktadır. Yargıtay HGK 2003/1-603 emsal kararına göre sahte imzayla yapılan tapu devirlerinde iyiniyetin korunmayacağı ilkesi uygulanmıştır. Tapu iptali ve davacı adına tesciline hükmedilmiştir.</data>
      <data key="d26">KARAR_ID_2019_890</data>
      <data key="d27">esasa_iliskin</data>
      <data key="d22">["TMK/683", "TMK/716"]</data>
      <data key="d23">["YRG_HGK_2003_603"]</data>
      <data key="d28">["sahte vekâletname", "tapu iptali", "iyiniyetin korunmaması"]</data>
      <data key="d25">eşya hukuku</data>
    </node>
    <node id="KARAR_ID_2017_4401">
      <data key="d0">karar</data>
      <data key="d1">İstanbul Anadolu 14. Asliye Hukuk Mahkemesi 2017/4401 esas 2018/1567 karar ispat yükü HMK madde 190 sözleşmeye aykırılık davası ispat yükümlülüğünün dağıtımı</data>
      <data key="d13">ilk_derece</data>
      <data key="d14">İstanbul Anadolu 14. Asliye Hukuk Mahkemesi</data>
