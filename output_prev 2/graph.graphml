      <data key="d0">karar</data>
      <data key="d1">İstanbul 3. Asliye Ticaret Mahkemesi 2011/1120 esas 2012/432 karar ticari sözleşme yorumu TBK geçiş dönemi 818 sayılı BK madde 18 sözleşmenin yorumu gerçek irade</data>
      <data key="d13">ilk_derece</data>
