      <data key="d45">TMK_M182</data>
    </node>
    <node id="TMK_M183">
      <data key="d0">madde</data>
      <data key="d1">Türk Medeni Kanunu madde 183 velayetin değiştirilmesi velayet kendisine bırakılan eşin yeniden evlenmesi diğer eşin çocuğun menfaatini tehlikeye sokan davranışları velayetin değiştirilmesine neden olabilir</data>
