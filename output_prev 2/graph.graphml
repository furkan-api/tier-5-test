      <data key="d25">borçlar hukuku</data>
    </node>
    <node id="KARAR_ID_2013_712">
      <data key="d0">karar</data>
      <data key="d1">Konya 1. Asliye Hukuk Mahkemesi 2013/712 esas 2014/310 karar tenkis davası miras saklı pay TMK madde 560 murisin ölüme bağlı tasarrufu saklı pay ihlali</data>
