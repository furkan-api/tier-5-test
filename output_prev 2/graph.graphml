      <data key="d19">mahkemenin velayet düzenleme görevi</data>
      <data key="d25">aile hukuku</data>
      <data key="d45">TMK_M182</data>
    </node>
    <node id="TMK_M182_F2">
      <data key="d0">fikra</data>
      <data key="d1">Velayetin kullanılması kendisine verilmeyen eşin çocuk ile kişisel ilişkisi, çocuğun ve diğer eşin hakları gözetilerek belirlenir.</data>
      <data key="d4">4721</data>
